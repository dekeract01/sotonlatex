% --------------------------------------------------------------------------------------
% Beamer custom layout and block definitions — University of Southampton
% --------------------------------------------------------------------------------------

% Core packages
\RequirePackage{tikz}
\RequirePackage{environ}                     % Defines NewEnviron
\usepackage{tcolorbox}
\usepackage{multirow}

% --------------------------------
% Title slide formatting
% --------------------------------
\setbeamercolor{title}{fg=white}
\setbeamercolor{author}{fg=white}
\setbeamercolor{institute}{fg=white}
\setbeamercolor*{subtitle}{fg=white}
\setbeamercolor*{date}{fg=white}
\setbeamerfont*{date}{size=\footnotesize}

\setbeamertemplate{title page}{
  \vspace{0.9cm}
  \begin{centering}
    \vspace{4mm}
    {\huge \usebeamercolor[fg]{title}\inserttitle\\[1.5cm]}
    \vspace{-8mm}
    {\large \usebeamercolor[fg]{subtitle}\insertauthor\\[0.5cm]}
    {\normalsize \usebeamercolor[fg]{subtitle}\insertinstitute\\[0cm]}
    \vspace{6mm}
    \usebeamerfont{date}
    \usebeamercolor[fg]{date}
    \normalsize \insertdate\\[1cm]
  \end{centering}
  \vspace{15mm}
  \begin{picture}(0,0)
    \put(0,25){\includegraphics[width=4.6cm]{images/logos/logo-soton-white.eps}}
    % \put(285,27){\includegraphics[width=3.8cm]{images/logos/logo-company-white.eps}}
  \end{picture}
}

% --------------------------------
% General slide formatting
% --------------------------------
\setbeamertemplate{frametitle}{
  \begin{picture}(0,0)
    \put(-8,-10){\centering\normalsize\bf\color{sotonblack}\insertframetitle}
    \put(-7,-20){\normalsize\color{sotonblack}\insertframesubtitle}
  \end{picture}
}

\setlength{\abovedisplayskip}{3pt}           % Compact equation spacing
\setlength{\belowdisplayskip}{3pt}
\raggedbottom                                % Avoid vertical stretching
\setbeamertemplate{itemize items}[circle]
\setbeamercolor{itemize item}{fg=sotonblack}
\setbeamertemplate{caption}[numbered]        % Numbered captions
\newcommand\textbox[1]{\parbox{.333\textwidth}{#1}}

% --------------------------------
% Colors and structure
% --------------------------------
\colorlet{alert}{sotongreen}
\setbeamercolor{structure}{fg=sotongreen}
\setbeamercolor{block title}{fg=white, bg=sotonanthrazit}
\setbeamercolor{block body}{bg=sotonlightgray}
\setbeamercolor{block title example}{fg=white, bg=soton2green}
\setbeamercolor{block body example}{bg=sotonlightgray}
\setbeamercolor{block title alerted}{fg=white, bg=sotongreen}
\setbeamercolor{block body alerted}{bg=sotonlightgray}
\setbeamercolor{alerted text}{fg=sotongreen}

% --------------------------------
% Block templates
% --------------------------------
\setbeamertemplate{block begin}{
  \setbeamercolor{itemize item}{fg=block title.bg}
  \setbeamercolor{item projected}{fg=block title.fg, bg=block title.bg}
  \setbeamercolor{caption name}{fg=alert}
  \vskip1.3ex
  \begin{beamercolorbox}[ht=2.4ex, dp=1ex, leftskip=0.75ex, rightskip=0.75ex]{block title}
    \usebeamerfont*{block title}\footnotesize\insertblocktitle
  \end{beamercolorbox}
  \nointerlineskip
  \usebeamerfont{block body}
  \begin{beamercolorbox}[dp=1ex, leftskip=0.75ex, rightskip=0.75ex, vmode]{block body}
    \vspace*{1ex}
}

\setbeamertemplate{block end}{
  \vskip0pt
  \end{beamercolorbox}
  \vskip1.3ex
}

% --------------------------------
% Example block (with fixed title)
% --------------------------------
\setbeamertemplate{block example begin}{
  \setbeamercolor{itemize item}{fg=block title example.bg}
  \setbeamercolor{item projected}{fg=block title example.fg, bg=block title example.bg}
  \vskip1.3ex
  \begin{beamercolorbox}[ht=2.4ex, dp=1ex, leftskip=0.75ex, rightskip=0.75ex]{block title example}
    \usebeamerfont*{block title example}\footnotesize Transition studies
  \end{beamercolorbox}
  \nointerlineskip
  \usebeamerfont{block body example}
  \begin{beamercolorbox}[dp=1ex, leftskip=0.75ex, rightskip=0.75ex, vmode]{block body example}
    \vspace*{1ex}
}

\setbeamertemplate{block example end}{
  \vskip0pt
  \end{beamercolorbox}
  \vskip1.3ex
}

% --------------------------------
% Section title slide
% --------------------------------
\setbeamertemplate{section page}{
  \begin{center}
    \vskip\baselineskip
    \insertsection
  \end{center}
}

\newcommand{\SectionPage}{
  \setbeamercolor{background canvas}{bg=\beamercolor, parent=section page}
  \begin{frame}[c, plain, noframenumbering]
    \LARGE \textcolor{white}{\sectionpage}
  \end{frame}
  \setbeamercolor{background canvas}{bg=white, parent=section page}
}

% --------------------------------
% Highlight box
% --------------------------------
\newtcolorbox{highlightbox}[1][Theorem:]{
  colback={#1}, colbacktitle=white, colframe={#1},
  boxrule=0pt, titlerule=0pt, arc=0pt
}

% --------------------------------
% Cancel-to commands
% --------------------------------
\let\cancelorigcolor\CancelColor

\newcommand{\CancelTo}[3][]{%
  \ifblank{#1}{}{\renewcommand{\CancelColor}{#1}}%
  \cancelto{#2}{#3}%
}

\newcommand{\canceltocolor}[3]{%
  {\renewcommand{\CancelColor}{#1}%
  \cancelto{#2}{#3}}%
}

\newcommand{\coloredcancelto}[3]{%
  \tikz[baseline=(math.base)]{
    \node[inner sep=0pt] (math) {$#3$};
    \draw[white] (math.south west) -- (math.north east);
    \draw[white, -stealth] (math.south west) -- ++(-0.5em, -0.5em)
      node[below] {$\textcolor{white}{#2}$};
  }
}

